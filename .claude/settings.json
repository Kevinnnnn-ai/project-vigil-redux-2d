{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(python -m *)",
      "Bash(python -c *)",
      "Bash(py -m *)",
      "Bash(pip install -r requirements.txt)",
      "Bash(pip freeze)",
      "Bash(pytest *)",
      "Bash(python -m pytest *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git stash*)",
      "Bash(git branch*)",
      "Bash(git switch*)",
      "Bash(git checkout *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh api *)"
    ]
  },
  "hooks": {}
}
